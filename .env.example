# ============================================================
# KONFIGURASI APLIKASI
# ============================================================

APP_NAME="POS App"
APP_ENV=local

# URL aplikasi — SESUAIKAN dengan lokasi project:
# - Docker (port 3000):  http://localhost:3000
# - XAMPP (tanpa vhost): http://localhost/pos/public
# - XAMPP (dengan vhost): http://pos.local
APP_URL=http://localhost/pos/public

# ============================================================
# KONFIGURASI DATABASE
# ============================================================

# Untuk DOCKER:
# DB_HOST=db
# DB_DATABASE=pos_db
# DB_USERNAME=user
# DB_PASSWORD=user

# Untuk XAMPP (DEFAULT — uncomment baris di bawah dan comment Docker):
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pos_db
DB_USERNAME=root
DB_PASSWORD=
